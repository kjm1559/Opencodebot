# =============================================================================
# Stock News API Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stocknews
POSTGRES_PASSWORD=stocknews
POSTGRES_DB=stocknews

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# External API Keys
# =============================================================================

# Finnhub API Key (REQUIRED)
# Get your key from: https://finnhub.io/
# Used for: real-time stock quotes, market data, company fundamentals
FINNHUB_API_KEY=your_finnhub_api_key_here

# AlphaVantage API Key (OPTIONAL)
# Get your key from: https://www.alphavantage.co/support/#api-key
# Used for: alternative stock data, forex, crypto, technical indicators
ALPHAVANTAGE_API_KEY=

# GNews API Key (OPTIONAL)
# Get your key from: https://gnews.io/
# Used for: stock news aggregation
GNEWS_API_KEY=

# =============================================================================
# FastAPI Application Configuration
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
